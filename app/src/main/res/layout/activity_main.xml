<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#1a1a2a">
    
    <TextView
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:text="🎮 3D GAME ENGINE"
        android:textSize="30sp"
        android:textColor="#ffaa00"
        android:gravity="center"/>
    
    <Button
        android:id="@+id/btn_create_game"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="10dp"
        android:text="➕ СОЗДАТЬ НОВУЮ ИГРУ"
        android:textSize="18sp"
        android:background="#ffaa00"/>
    
    <Button
        android:id="@+id/btn_my_games"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="10dp"
        android:text="📁 МОИ ИГРЫ"
        android:textSize="18sp"/>
    
    <Button
        android:id="@+id/btn_store"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="10dp"
        android:text="🛒 МАГАЗИН ИГР"
        android:textSize="18sp"/>
    
    <Button
        android:id="@+id/btn_profile"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="10dp"
        android:text="👤 ПРОФИЛЬ / ВХОД"
        android:textSize="18sp"/>
    
    <Button
        android:id="@+id/btn_settings"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="10dp"
        android:text="⚙️ НАСТРОЙКИ"
        android:textSize="18sp"/>
    
</LinearLayout>
